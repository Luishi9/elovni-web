# ── Desarrollo local ──────────────────────────────────────────────────────────
# Usa URL relativa para que el proxy de Vite reenvíe las peticiones al backend
VITE_API_URL=/api/v1

# ── Producción (Netlify) ───────────────────────────────────────────────────────
# Sustituye por tu dominio o IP del VPS. Configúrala en:
#   Netlify → Site settings → Environment variables → VITE_API_URL
# VITE_API_URL=https://api.tudominio.com/api/v1
